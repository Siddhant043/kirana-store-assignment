# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API key for Claude Agent SDK
ANTHROPIC_API_KEY=

# Hosted Whisper API key (OpenAI or Groq OpenAI-compatible endpoint)
WHISPER_API_KEY=

# Optional Whisper endpoint override (default: OpenAI; set for Groq etc.)
# WHISPER_API_BASE_URL=https://api.openai.com/v1
# WHISPER_MODEL=whisper-1

# Postgres connection URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://kirana:kirana@postgres:5432/kirana

# Primary loop model (configurable; default Sonnet)
CLAUDE_MODEL_ID=claude-sonnet-5
